{
  "name": "gha-security-scanner",
  "version": "0.0.1",
  "private": true,
  "description": "Generates and uploads SARIF files to GitHub Advanced Security",
  "keywords": [
    "github",
    "actions",
    "codeql",
    "sarif"
  ],
  "homepage": "https://github.com/Workiva/gha-security-scanner",
  "bugs": {
    "url": "https://github.com/Workiva/gha-security-scanner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Workiva/gha-security-scanner.git"
  },
  "license": "UNLICENSED",
  "author": "Workiva",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "all": "npm run format:write && npm run lint && npm run test && npm run package",
    "bundle": "npm run format:write && npm run package",
    "format:check": "npx prettier --check .",
    "format:write": "npx prettier --write .",
    "lint": "npx eslint . -c ./.eslintrc.json",
    "package": "npx ncc build src/index.ts -o dist --source-map",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest"
  },
  "jest": {
    "clearMocks": true,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "verbose": true
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/tool-cache": "^2.0.1",
    "@types/js-yaml": "^4.0.9"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "eslint-plugin-github": "^5.1.4",
    "eslint-plugin-jest": "^28.10.0",
    "eslint-plugin-jsonc": "^2.18.2",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.4.2",
    "prettier-eslint": "^16.3.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
